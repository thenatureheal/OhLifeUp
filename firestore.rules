rules_version = '2';

// OhLifeUp Firestore security rules.
// 방식 A: 프론트엔드에서 Firestore SDK로 직접 read/write 하되, 아래 규칙으로 보호.
// 배포: firebase deploy --only firestore:rules
//   또는 Firebase 콘솔 → Firestore Database → 규칙 에 붙여넣기.
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidPost() {
      let d = request.resource.data;
      return d.keys().hasOnly(['category', 'name', 'title', 'content', 'createdAt'])
        && d.category in ['china', 'coaching']
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 100
        && d.title is string && d.title.size() >= 1 && d.title.size() <= 255
        && d.content is string && d.content.size() >= 1 && d.content.size() <= 10000
        && d.createdAt == request.time;
    }

    function isValidPayment() {
      let d = request.resource.data;
      return d.keys().hasOnly(['name', 'phone', 'email', 'orderId', 'amount', 'currency', 'packageName', 'createdAt'])
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 100
        && d.phone is string && d.phone.size() >= 1 && d.phone.size() <= 30
        && d.email is string && d.email.size() <= 200
        && d.orderId is string && d.orderId.size() <= 100
        && d.amount is string && d.amount.size() <= 20
        && d.currency is string && d.currency.size() <= 10
        && d.packageName is string && d.packageName.size() <= 200
        && d.createdAt == request.time;
    }

    match /posts/{postId} {
      // 게시판은 공개 — 누구나 목록/상세 조회 가능
      allow read: if true;

      // 글 작성: 필드/타입/길이 검증. 허용된 필드만(비밀번호 등 추가 필드 금지),
      // createdAt 은 서버 시간이어야 함.
      allow create: if isValidPost();

      // 클라이언트에서 수정/삭제 금지 (필요 시 추후 Cloud Functions 로)
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      // 결제 내역 조회(이름+연락처)를 위해 읽기 허용.
      // ⚠ 보안 주의: 방식 A(클라이언트 직접 접근)에서는 payments 가 읽기 가능해야
      // 조회 쿼리가 동작하므로, 이 데이터는 완전히 비공개가 아닙니다.
      // 운영 환경에서는 이 조회를 서버(Route Handler / Admin SDK)로 옮기고
      // 아래 read 를 false 로 잠그는 것을 권장합니다.
      allow read: if true;

      // 결제 성공 시 기록. 필드/타입/길이 검증.
      allow create: if isValidPayment();

      // 수정/삭제 금지
      allow update, delete: if false;
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
