rules_version = '2';

// OhLifeUp Firestore security rules.
// 방식 A: 프론트엔드에서 Firestore SDK로 직접 read/write 하되, 아래 규칙으로 보호.
// 관리자 데이터(문의/알림/민감 PII)는 isAdmin() 이메일 허용목록으로 잠급니다.
// 배포: firebase deploy --only firestore:rules
//   또는 Firebase 콘솔 → Firestore Database → 규칙 에 붙여넣기.
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠ 이 목록은 lib/admin.ts 의 ADMIN_EMAILS / NEXT_PUBLIC_ADMIN_EMAILS 와
    //    반드시 동일하게 유지하세요. 관리자를 추가하려면 여기에 이메일을 추가합니다.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['thenatureheal@gmail.com'];
    }

    function isValidPost() {
      let d = request.resource.data;
      return d.keys().hasOnly(['category', 'name', 'title', 'content', 'createdAt'])
        && d.category in ['china', 'coaching']
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 100
        && d.title is string && d.title.size() >= 1 && d.title.size() <= 255
        && d.content is string && d.content.size() >= 1 && d.content.size() <= 10000
        && d.createdAt == request.time;
    }

    function isValidPayment() {
      let d = request.resource.data;
      return d.keys().hasOnly(['name', 'phone', 'email', 'orderId', 'amount', 'currency', 'packageName', 'status', 'createdAt'])
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 100
        && d.phone is string && d.phone.size() >= 1 && d.phone.size() <= 30
        && d.email is string && d.email.size() <= 200
        && d.orderId is string && d.orderId.size() <= 100
        && d.amount is string && d.amount.size() <= 20
        && d.currency is string && d.currency.size() <= 10
        && d.packageName is string && d.packageName.size() <= 200
        && d.status == 'paid'
        && d.createdAt == request.time;
    }

    // 결제 상태 변경은 status 필드만 바꿀 수 있고 값은 정해진 3가지 중 하나.
    function isValidStatusUpdate() {
      let d = request.resource.data;
      return d.diff(resource.data).affectedKeys().hasOnly(['status'])
        && d.status in ['paid', 'refunded', 'cancelled'];
    }

    function isValidInquiry() {
      let d = request.resource.data;
      return d.keys().hasOnly(['name', 'phone', 'email', 'message', 'status', 'createdAt'])
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 100
        && d.phone is string && d.phone.size() <= 30
        && d.email is string && d.email.size() <= 200
        && d.message is string && d.message.size() >= 1 && d.message.size() <= 5000
        && d.status == 'new'
        && d.createdAt == request.time;
    }

    // 공개 액션이 만드는 알림(payment/inquiry)만 검증. refund/cancel 은 관리자만 생성.
    function isValidNotification() {
      let d = request.resource.data;
      return d.keys().hasOnly(['type', 'title', 'message', 'refId', 'read', 'createdAt'])
        && d.type in ['payment', 'inquiry']
        && d.title is string && d.title.size() <= 200
        && d.message is string && d.message.size() <= 500
        && d.refId is string && d.refId.size() <= 100
        && d.read == false
        && d.createdAt == request.time;
    }

    match /posts/{postId} {
      // 게시판은 공개 — 누구나 목록/상세 조회 가능
      allow read: if true;
      allow create: if isValidPost();
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      // 결제 내역 조회(이름+연락처)를 위해 읽기 허용.
      // ⚠ 이름/전화/이메일은 조회 기능 때문에 공개 읽기 상태입니다. 주소·생년월일·성별
      //   등 민감 PII 는 아래 paymentDetails(관리자 전용)에 별도 저장되어 노출되지 않습니다.
      allow read: if true;
      allow create: if isValidPayment();
      // 상태(결제/환불/취소) 변경은 관리자만.
      allow update: if isAdmin() && isValidStatusUpdate();
      allow delete: if false;
    }

    match /products/{productId} {
      // 상품/금액은 결제 페이지 표시 + 서버 주문 생성 시 읽어야 하므로 공개 읽기.
      // 등록/수정/삭제는 관리자만 (서버가 이 금액으로 청구하므로 조작 불가).
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /paymentDetails/{paymentId} {
      // 관리자가 입력하는 민감 PII(주소/생년월일/성별/메모). 관리자만 접근.
      allow read, write: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      // 문의 작성은 공개, 조회/답장은 관리자만.
      allow read: if isAdmin();
      allow create: if isValidInquiry();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      // 알림 기록: 공개 액션(결제/문의)이 생성 가능(검증), 그 외는 관리자만.
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidNotification();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
