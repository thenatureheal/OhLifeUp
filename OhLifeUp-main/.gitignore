# ═══════════════════════════════════════
#  OhLifeUp — .gitignore
# ═══════════════════════════════════════

# ── Python ──────────────────────────────
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.env
.env.*

# ── Database (auto-generated on first run) ──
*.db
*.sqlite
*.sqlite3

# ── Node / Frontend ─────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ── Logs ────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ─────────────────────────
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
