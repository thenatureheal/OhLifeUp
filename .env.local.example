# ─────────────────────────────────────────────────────────────
# OhLifeUp 환경변수 예시
# 이 파일을 복사해서 `.env.local` 로 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# .env.local 은 git 에 커밋되지 않습니다 (.gitignore).
# NEXT_PUBLIC_ 접두사 키는 브라우저에 노출됩니다(공개 안전 값만). 접두사 없는 키는
# 서버 전용 비밀값이므로 절대 NEXT_PUBLIC_ 을 붙이지 마세요.
# ─────────────────────────────────────────────────────────────

# ── Firebase (사무실 Firebase 콘솔 → 프로젝트 설정 → 내 앱 → SDK 설정/구성) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 관리자(admin) 허용 이메일 ──
# 콤마로 여러 명 지정 가능. 이 목록의 이메일 계정만 관리자 화면(/admin)에 접근하고
# 결제·문의·알림 데이터를 읽을 수 있습니다. 미설정 시 thenatureheal@gmail.com.
# ⚠ 이 값과 firestore.rules 의 isAdmin() 이메일 목록을 반드시 동일하게 유지하세요.
NEXT_PUBLIC_ADMIN_EMAILS=thenatureheal@gmail.com

# ── 결제 웹훅 (환불/취소 자동 동기화) ──
# 웹훅 서버가 Firestore에 상태를 쓰기 위해 로그인하는 전용 계정(Airwallex 웹훅이 사용).
# 값은 로컬 webhook-credentials.secret.txt 파일 참조(절대 커밋 금지).
WEBHOOK_FIREBASE_EMAIL=
WEBHOOK_FIREBASE_PASSWORD=

# ── Airwallex (서버사이드 결제 · Hosted Payment Page) — 유일 결제수단 ──
# demo.airwallex.com(샌드박스) 또는 www.airwallex.com(운영) → Developer → API Keys.
# 국내카드를 USD 해외결제로 처리.
#
# [서버 — 비공개] ⚠ 절대 NEXT_PUBLIC_ 붙이지 마세요(브라우저 노출됨).
AIRWALLEX_ENV=demo                    # demo(샌드박스) | prod(운영)
AIRWALLEX_CLIENT_ID=                  # API Keys 페이지 상단의 Client ID
AIRWALLEX_API_KEY=                    # 스코프 키 생성 시 한 번만 표시된 API Key(Secret)
AIRWALLEX_WEBHOOK_SECRET=             # Developer → Webhooks 등록 시 나오는 Secret
AIRWALLEX_AMOUNT=29.00                # 서버가 통제하는 청구 금액(상품 미선택 시 fallback)
AIRWALLEX_CURRENCY=USD                # 결제 통화(국내카드→USD 해외결제)
#
# [프론트 — 공개] airwallex.js 초기화 + 결제 버튼 노출용 (비밀값 아님).
NEXT_PUBLIC_AIRWALLEX_ENV=demo        # demo | prod (미설정 시 Airwallex 버튼 숨김)
