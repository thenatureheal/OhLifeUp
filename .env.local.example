# ─────────────────────────────────────────────────────────────
# OhLifeUp 환경변수 예시
# 이 파일을 복사해서 `.env.local` 로 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# .env.local 은 git 에 커밋되지 않습니다 (.gitignore).
# 모든 키가 NEXT_PUBLIC_ 접두사 → 브라우저에 노출됩니다.
# (Firebase 클라이언트 키는 공개돼도 무방하며, Firestore 보안 규칙으로 보호합니다.)
# ─────────────────────────────────────────────────────────────

# ── Firebase (사무실 Firebase 콘솔 → 프로젝트 설정 → 내 앱 → SDK 설정/구성) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 관리자(admin) 허용 이메일 ──
# 콤마로 여러 명 지정 가능. 이 목록의 이메일 계정만 관리자 화면(/admin)에 접근하고
# 결제·문의·알림 데이터를 읽을 수 있습니다. 미설정 시 thenatureheal@gmail.com.
# ⚠ 이 값과 firestore.rules 의 isAdmin() 이메일 목록을 반드시 동일하게 유지하세요.
NEXT_PUBLIC_ADMIN_EMAILS=thenatureheal@gmail.com

# ── PayPal (서버사이드 결제) ──
# 자세한 발급/설정/테스트/실거래 전환 절차는 docs/PAYPAL_SETUP.md 참고.
#
# [프론트 — 공개] 버튼 렌더링용
NEXT_PUBLIC_PAYPAL_CLIENT_ID=        # PayPal 앱의 Client ID (sandbox 또는 live)
NEXT_PUBLIC_PAYPAL_ENV=sandbox       # 화면 "테스트 모드" 안내 표시용: sandbox | live
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PAYPAL_AMOUNT=122.00     # 화면 표시용 금액
#
# [서버 — 비공개] 주문 생성/승인용. ⚠ 절대 NEXT_PUBLIC_ 붙이지 마세요(브라우저 노출됨).
PAYPAL_CLIENT_SECRET=                # PayPal 앱의 Secret
PAYPAL_ENV=sandbox                   # 실제 결제 환경: sandbox | live
PAYPAL_AMOUNT=122.00                 # 실제 청구 금액(서버가 통제). 미설정 시 NEXT_PUBLIC_PAYPAL_AMOUNT 사용
PAYPAL_CURRENCY=USD
# PAYPAL_CLIENT_ID=                   # (선택) 미설정 시 NEXT_PUBLIC_PAYPAL_CLIENT_ID 사용
