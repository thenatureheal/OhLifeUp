# ─────────────────────────────────────────────────────────────
# OhLifeUp 환경변수 예시
# 이 파일을 복사해서 `.env.local` 로 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# .env.local 은 git 에 커밋되지 않습니다 (.gitignore).
# 모든 키가 NEXT_PUBLIC_ 접두사 → 브라우저에 노출됩니다.
# (Firebase 클라이언트 키는 공개돼도 무방하며, Firestore 보안 규칙으로 보호합니다.)
# ─────────────────────────────────────────────────────────────

# ── Firebase (사무실 Firebase 콘솔 → 프로젝트 설정 → 내 앱 → SDK 설정/구성) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 관리자(admin) 허용 이메일 ──
# 콤마로 여러 명 지정 가능. 이 목록의 이메일 계정만 관리자 화면(/admin)에 접근하고
# 결제·문의·알림 데이터를 읽을 수 있습니다. 미설정 시 thenatureheal@gmail.com.
# ⚠ 이 값과 firestore.rules 의 isAdmin() 이메일 목록을 반드시 동일하게 유지하세요.
NEXT_PUBLIC_ADMIN_EMAILS=thenatureheal@gmail.com

# ── PayPal (서버사이드 결제) ──
# 자세한 발급/설정/테스트/실거래 전환 절차는 docs/PAYPAL_SETUP.md 참고.
#
# [프론트 — 공개] 버튼 렌더링용
NEXT_PUBLIC_PAYPAL_CLIENT_ID=        # PayPal 앱의 Client ID (sandbox 또는 live)
NEXT_PUBLIC_PAYPAL_ENV=sandbox       # 화면 "테스트 모드" 안내 표시용: sandbox | live
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PAYPAL_AMOUNT=122.00     # 화면 표시용 금액
#
# [서버 — 비공개] 주문 생성/승인용. ⚠ 절대 NEXT_PUBLIC_ 붙이지 마세요(브라우저 노출됨).
PAYPAL_CLIENT_SECRET=                # PayPal 앱의 Secret
PAYPAL_ENV=sandbox                   # 실제 결제 환경: sandbox | live
PAYPAL_AMOUNT=122.00                 # 실제 청구 금액(서버가 통제). 미설정 시 NEXT_PUBLIC_PAYPAL_AMOUNT 사용
PAYPAL_CURRENCY=USD
# PAYPAL_CLIENT_ID=                   # (선택) 미설정 시 NEXT_PUBLIC_PAYPAL_CLIENT_ID 사용

# ── PayPal 웹훅 (결제/환불/취소 자동 동기화) — 선택 기능 ──
# PayPal 개발자 대시보드에서 웹훅 등록 시 나오는 Webhook ID.
# 자세한 활성화 절차: docs/PAYPAL_WEBHOOK.md
PAYPAL_WEBHOOK_ID=
# 웹훅 서버가 Firestore에 상태를 쓰기 위해 로그인하는 전용 계정.
# 값은 로컬 webhook-credentials.secret.txt 파일 참조(절대 커밋 금지).
# ※ Airwallex 웹훅도 이 동일한 계정으로 Firestore에 상태를 씁니다.
WEBHOOK_FIREBASE_EMAIL=
WEBHOOK_FIREBASE_PASSWORD=

# ── Airwallex (서버사이드 결제 · Hosted Payment Page) ──
# demo.airwallex.com → Developer → API Keys 에서 발급 (샌드박스는 demo 환경).
# 국내카드를 USD 해외결제로 처리. PayPal 과 병행 노출됩니다.
#
# [서버 — 비공개] ⚠ 절대 NEXT_PUBLIC_ 붙이지 마세요(브라우저 노출됨).
AIRWALLEX_ENV=demo                    # demo(샌드박스) | prod(운영)
AIRWALLEX_CLIENT_ID=                  # API Keys 페이지 상단의 Client ID
AIRWALLEX_API_KEY=                    # 스코프 키 생성 시 한 번만 표시된 API Key(Secret)
AIRWALLEX_WEBHOOK_SECRET=             # Developer → Webhooks 등록 시 나오는 Secret
AIRWALLEX_AMOUNT=29.00                # 서버가 통제하는 청구 금액(상품 미선택 시 fallback)
AIRWALLEX_CURRENCY=USD                # 결제 통화(국내카드→USD 해외결제)
#
# [프론트 — 공개] airwallex.js 초기화 + 결제 버튼 노출용 (비밀값 아님).
NEXT_PUBLIC_AIRWALLEX_ENV=demo        # demo | prod (미설정 시 Airwallex 버튼 숨김)
